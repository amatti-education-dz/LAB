{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information for staff members",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "technician", "teacher"] }
      },
      "required": ["uid", "role"]
    },
    "Settings": {
      "title": "User Settings",
      "description": "Personalized settings for the user",
      "type": "object",
      "properties": {
        "jobTitle": { "type": "string" },
        "grade": { "type": "string" },
        "specialty": { "type": "string" },
        "directorate": { "type": "string" },
        "commune": { "type": "string" },
        "school": { "type": "string" },
        "address": { "type": "string" },
        "levels": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "groups": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Chemical": {
      "title": "Chemical",
      "description": "Chemical reagent in inventory",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "formula": { "type": "string" },
        "cas": { "type": "string" },
        "purity": { "type": "string" },
        "storageTemp": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "hazardClass": { "type": "string" },
        "location": { "type": "string" }
      },
      "required": ["name", "quantity", "unit"]
    },
    "Equipment": {
      "title": "Equipment",
      "description": "Laboratory equipment or glassware",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["glassware", "tech", "other"] },
        "serialNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["functional", "maintenance", "broken"] },
        "totalQuantity": { "type": "number" },
        "availableQuantity": { "type": "number" },
        "brokenQuantity": { "type": "number" },
        "lastCalibration": { "type": "string", "format": "date" },
        "nextCalibration": { "type": "string", "format": "date" }
      },
      "required": ["name", "type", "totalQuantity"]
    },
    "Waste": {
      "title": "Waste",
      "description": "Chemical waste record",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "hazardClass": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["collecting", "full", "disposed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "quantity", "status"]
    },
    "Incident": {
      "title": "Incident",
      "description": "Safety incident record",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "severity": { "type": "string", "enum": ["minor", "moderate", "high"] },
        "status": { "type": "string", "enum": ["investigating", "resolved", "closed"] },
        "description": { "type": "string" },
        "reporterUid": { "type": "string" }
      },
      "required": ["type", "date", "severity", "status"]
    },
    "TimetableEntry": {
      "title": "Timetable Entry",
      "description": "Scheduled lab session",
      "type": "object",
      "properties": {
        "labId": { "type": "string" },
        "teacherName": { "type": "string" },
        "subject": { "type": "string" },
        "classLevel": { "type": "string" },
        "day": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "status": { "type": "string", "enum": ["confirmed", "pending", "cancelled"] }
      },
      "required": ["labId", "teacherName", "day", "startTime", "endTime"]
    },
    "LabReservation": {
      "title": "Lab Reservation",
      "description": "A reservation for a specific lab at a specific time",
      "type": "object",
      "properties": {
        "labName": { "type": "string" },
        "day": { "type": "string" },
        "time": { "type": "string" },
        "teacher": { "type": "string" },
        "subject": { "type": "string" },
        "group": { "type": "string" },
        "status": { "type": "string", "enum": ["confirmed", "pending", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["labName", "day", "time", "teacher", "subject", "group", "status"]
    },
    "ExperimentLog": {
      "title": "Experiment Log",
      "description": "A record of an experiment performed in the lab",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "teacher": { "type": "string" },
        "class": { "type": "string" },
        "subject": { "type": "string" },
        "equipmentUsed": { "type": "array", "items": { "type": "string" } },
        "chemicalsUsed": { "type": "array", "items": { "type": "string" } },
        "observations": { "type": "string" },
        "status": { "type": "string", "enum": ["planned", "completed", "cancelled"] }
      },
      "required": ["title", "date", "teacher", "class", "status"]
    },
    "DailyReport": {
      "title": "Daily Report",
      "description": "Daily laboratory activity report",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "dayName": { "type": "string" },
        "rows": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "teacher": { "type": "string" },
              "time": { "type": "string" },
              "class": { "type": "string" },
              "activity": { "type": "string" },
              "equipment": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        },
        "labNotes": { "type": "string" },
        "supervisorNotes": { "type": "string" },
        "directorNotes": { "type": "string" },
        "uid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "uid"]
    }
  },
  "firestore": {
    "users": {
      "schema": "UserProfile",
      "description": "Collection of user profiles"
    },
    "schools/{schoolId}/chemicals": {
      "schema": "Chemical",
      "description": "User-specific collection of chemical reagents"
    },
    "users/{userId}/equipment": {
      "schema": "Equipment",
      "description": "User-specific collection of lab equipment and glassware"
    },
    "users/{userId}/waste": {
      "schema": "Waste",
      "description": "User-specific collection of chemical waste records"
    },
    "users/{userId}/incidents": {
      "schema": "Incident",
      "description": "User-specific collection of safety incidents"
    },
    "users/{userId}/timetable": {
      "schema": "TimetableEntry",
      "description": "User-specific collection of scheduled lab sessions"
    },
    "users/{userId}/settings": {
      "schema": "Settings",
      "description": "User-specific application settings"
    },
    "users/{userId}/daily_reports": {
      "schema": "DailyReport",
      "description": "User-specific collection of daily laboratory reports"
    },
    "users/{userId}/teachers": {
      "schema": "UserProfile",
      "description": "User-specific collection of teachers/staff"
    },
    "users/{userId}/reports": {
      "schema": "DailyReport",
      "description": "User-specific collection of generated reports"
    },
    "users/{userId}/incident_logs": {
      "schema": "Incident",
      "description": "User-specific collection of safety incident logs"
    },
    "users/{userId}/safety_equipment": {
      "schema": "Equipment",
      "description": "User-specific collection of safety equipment"
    },
    "users/{userId}/maintenance_logs": {
      "schema": "object",
      "description": "User-specific collection of maintenance logs"
    },
    "users/{userId}/lab_schedule": {
      "schema": "LabReservation",
      "description": "User-specific collection of lab reservations"
    },
    "users/{userId}/experiment_logs": {
      "schema": "ExperimentLog",
      "description": "User-specific collection of experiment logs"
    }
  }
}
