{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information for staff members",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "technician", "teacher"] }
      },
      "required": ["uid", "role"]
    },
    "Settings": {
      "title": "User Settings",
      "description": "Personalized settings for the user",
      "type": "object",
      "properties": {
        "jobTitle": { "type": "string" },
        "grade": { "type": "string" },
        "specialty": { "type": "string" },
        "directorate": { "type": "string" },
        "commune": { "type": "string" },
        "school": { "type": "string" },
        "address": { "type": "string" },
        "levels": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "groups": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Chemical": {
      "title": "Chemical",
      "description": "Chemical reagent in inventory",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "formula": { "type": "string" },
        "cas": { "type": "string" },
        "purity": { "type": "string" },
        "storageTemp": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "hazardClass": { "type": "string" },
        "location": { "type": "string" }
      },
      "required": ["name", "quantity", "unit"]
    },
    "Equipment": {
      "title": "Equipment",
      "description": "Laboratory equipment or glassware",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["glassware", "tech", "other"] },
        "serialNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["functional", "maintenance", "broken"] },
        "totalQuantity": { "type": "number" },
        "availableQuantity": { "type": "number" },
        "brokenQuantity": { "type": "number" },
        "lastCalibration": { "type": "string", "format": "date" },
        "nextCalibration": { "type": "string", "format": "date" }
      },
      "required": ["name", "type", "totalQuantity"]
    },
    "Waste": {
      "title": "Waste",
      "description": "Chemical waste record",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "hazardClass": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["collecting", "full", "disposed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "quantity", "status"]
    },
    "Incident": {
      "title": "Incident",
      "description": "Safety incident record",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "severity": { "type": "string", "enum": ["minor", "moderate", "high"] },
        "status": { "type": "string", "enum": ["investigating", "resolved", "closed"] },
        "description": { "type": "string" },
        "reporterUid": { "type": "string" }
      },
      "required": ["type", "date", "severity", "status"]
    },
    "TimetableEntry": {
      "title": "Timetable Entry",
      "description": "Scheduled lab session",
      "type": "object",
      "properties": {
        "labId": { "type": "string" },
        "teacherName": { "type": "string" },
        "subject": { "type": "string" },
        "classLevel": { "type": "string" },
        "day": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "status": { "type": "string", "enum": ["confirmed", "pending", "cancelled"] }
      },
      "required": ["labId", "teacherName", "day", "startTime", "endTime"]
    },
    "DailyReport": {
      "title": "Daily Report",
      "description": "Daily laboratory activity report",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "dayName": { "type": "string" },
        "rows": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "teacher": { "type": "string" },
              "time": { "type": "string" },
              "class": { "type": "string" },
              "activity": { "type": "string" },
              "equipment": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        },
        "labNotes": { "type": "string" },
        "supervisorNotes": { "type": "string" },
        "directorNotes": { "type": "string" },
        "uid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "uid"]
    }
  },
  "firestore": {
    "users": {
      "schema": "UserProfile",
      "description": "Collection of user profiles"
    },
    "chemicals": {
      "schema": "Chemical",
      "description": "Collection of chemical reagents"
    },
    "equipment": {
      "schema": "Equipment",
      "description": "Collection of lab equipment and glassware"
    },
    "waste": {
      "schema": "Waste",
      "description": "Collection of chemical waste records"
    },
    "incidents": {
      "schema": "Incident",
      "description": "Collection of safety incidents"
    },
    "timetable": {
      "schema": "TimetableEntry",
      "description": "Collection of scheduled lab sessions"
    },
    "settings": {
      "schema": "Settings",
      "description": "User-specific application settings"
    },
    "daily_reports": {
      "schema": "DailyReport",
      "description": "Collection of daily laboratory reports"
    }
  }
}
