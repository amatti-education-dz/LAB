rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email (optional), phoneNumber (optional), role, displayName
    // Required: uid, role
    // Collection: chemicals
    // Fields: name, formula, quantity, unit, location, expiryDate, hazardClass
    //
    // Collection: equipment
    // Fields: name, category, status, quantity, location, lastMaintenance
    //
    // Collection: teachers
    // Fields: name, subject, email, phone, classes
    //
    // Collection: safety_equipment
    // Fields: name, status, lastCheck, location, type
    //
    // Collection: incident_logs
    // Fields: title, date, severity, description, reporter
    //
    // Collection: reports
    // Fields: title, generatedAt, stats, type
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "faycalassoul@gmail.com"));
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function isValidString(field, min, max) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= min && 
             request.resource.data[field].size() <= max;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /settings/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /daily_reports/{id} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (request.resource.data.createdBy == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /chemicals/{id} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || (isAuthenticated() && hasRequiredFields(['name']));
      allow delete: if isAuthenticated();
    }

    match /equipment/{id} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || (isAuthenticated() && hasRequiredFields(['name']));
      allow delete: if isAuthenticated();
    }

    match /teachers/{id} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || (isAuthenticated() && hasRequiredFields(['name']));
      allow delete: if isAuthenticated();
    }

    match /safety_equipment/{id} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && hasRequiredFields(['name', 'status']);
      allow delete: if isAuthenticated();
    }

    match /incident_logs/{id} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && hasRequiredFields(['title', 'severity']);
      allow delete: if isAuthenticated();
    }

    match /reports/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields(['title', 'generatedAt']);
      allow update, delete: if isAdmin();
    }
  }
}
