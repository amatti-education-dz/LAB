rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((request.auth.token.email == "faycalassoul@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin'));
    }

    // Global admin access
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // User-scoped data
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }

    // Settings
    match /settings/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }

    // Connection test
    match /_connection_test_/{docId} {
      allow read: if isAuthenticated();
    }
  }
}
